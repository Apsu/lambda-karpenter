# Project defaults — committed to the repo.
# Personal overrides and secrets go in .env.local (gitignored).

VERSION=v0.4.1
IMAGE_REPO=apsu/lambda-karpenter

# Cluster configuration (override in .env.local)
#CLUSTER_NAME=
#KUBECONFIG=

# Lambda API
#LAMBDA_API_TOKEN=
#LAMBDA_API_BASE_URL=https://cloud.lambda.ai

# Build
#PLATFORMS=linux/amd64,linux/arm64

# Deploy
#GPU_OPERATOR_VERSION=v25.10.1
