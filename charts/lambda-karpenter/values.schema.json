{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["config"],
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {"type": "string"},
        "tag": {"type": "string"},
        "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "replicaCount": {"type": "integer", "minimum": 1},
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"},
        "name": {"type": "string"},
        "annotations": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"}
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"},
        "maxUnavailable": {"type": "integer", "minimum": 1}
      }
    },
    "resources": {"type": "object"},
    "nodeSelector": {"type": "object"},
    "tolerations": {"type": "array"},
    "affinity": {"type": "object"},
    "config": {
      "type": "object",
      "required": ["clusterName", "apiTokenSecret"],
      "properties": {
        "clusterName": {"type": "string", "minLength": 1},
        "apiTokenSecret": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "key": {"type": "string"}
          }
        },
        "apiBaseUrl": {"type": "string", "format": "uri"},
        "apiRps": {"type": "integer", "minimum": 1},
        "launchMinIntervalSeconds": {"type": "integer", "minimum": 0},
        "instanceTypeCacheTtl": {"type": "string"},
        "featureGates": {"type": "string"}
      }
    },
    "extraEnv": {"type": "array"}
  }
}
