{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["config"],
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {"type": "string"},
        "tag": {"type": "string"},
        "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "replicaCount": {"type": "integer", "minimum": 1},
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"},
        "name": {"type": "string"},
        "annotations": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"}
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"},
        "maxUnavailable": {"type": "integer", "minimum": 1}
      }
    },
    "resources": {"type": "object"},
    "nodeSelector": {"type": "object"},
    "tolerations": {"type": "array"},
    "affinity": {"type": "object"},
    "config": {
      "type": "object",
      "required": ["clusterName"],
      "properties": {
        "clusterName": {"type": "string", "minLength": 1},
        "apiTokenSecret": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "key": {"type": "string"}
          }
        },
        "apiBaseUrl": {"type": "string", "format": "uri"},
        "apiRps": {"type": "integer", "minimum": 1},
        "launchMinIntervalSeconds": {"type": "integer", "minimum": 0},
        "instanceTypeCacheTtl": {"type": "string"},
        "featureGates": {"type": "string"}
      }
    },
    "extraEnv": {"type": "array"},
    "cluster": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["", "kubeadm", "rke2"]},
        "controllerIP": {"type": "string"},
        "joinToken": {"type": "string"}
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": {"type": "boolean"},
        "token": {"type": "string"}
      }
    },
    "nodeClass": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string"},
        "region": {"type": "string"},
        "instanceType": {"type": "string"},
        "image": {
          "type": "object",
          "properties": {
            "family": {"type": "string"}
          }
        },
        "sshKeyNames": {"type": "array", "items": {"type": "string"}},
        "tags": {"type": "object", "additionalProperties": {"type": "string"}},
        "userData": {"type": "string"}
      }
    },
    "nodePool": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string"},
        "instanceTypes": {"type": "array", "items": {"type": "string"}},
        "architecture": {"type": "string"},
        "limits": {
          "type": "object",
          "properties": {
            "nodes": {"type": "integer", "minimum": 1}
          }
        },
        "disruption": {
          "type": "object",
          "properties": {
            "consolidationPolicy": {"type": "string"},
            "consolidateAfter": {"type": "string"}
          }
        }
      }
    }
  }
}
